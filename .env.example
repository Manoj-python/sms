# --- SMSquare Customer Portal (Django) — environment template --------------
# Copy to .env and fill in. NEVER commit the real .env.
# This is a separate project from ../smsquare-portal (FastAPI) — its own
# .env, own local DB file, own credentials if you want it isolated. The same
# real production AllCloud/SmsCountry values can be reused here verbatim
# once you're ready to point this at production.

# uat | prod  (selects which AllCloud credential set + base URL is used)
APP_ENV=uat

# Secret for signing session cookies (generate: python -c "import secrets;print(secrets.token_urlsafe(48))")
SECRET_KEY=change-me

# Fernet key for encrypting sensitive DB columns
# (generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change-me

# Portal's own DB (sessions/otp_log/pg_transactions/lms_api_log/audit_log —
# NO loan data lives here). sqlite:///path.db for zero-setup local dev, or
# mysql+pymysql://user:pass@host:port/dbname for the same MySQL schema as
# db/schema.sql (shared structure with the FastAPI version, not the same row
# data unless you point both at the same database).
DATABASE_URL=sqlite:///portal_dev.db

# --- AllCloud LMS: UAT (dynamic per-call signing — unverified against real
# AllCloud; see ../smsquare-portal/README.md) --------------------------------
LMS_MOCK=true                       # true = serve realistic fixtures, no LMS calls
LMS_BASE_URL_UAT=https://uat-apiv2-smsquare.allcloud.app
ALLCLOUD_AUTH_URL=https://prod-auth-ace.allcloud.app/enterprise-generatetoken

ALLCLOUD_APPID_UAT=
ALLCLOUD_SECRET_UAT=
ALLCLOUD_USERTOKEN_UAT=
ALLCLOUD_APIKEY_UAT=

# --- AllCloud LMS: PROD (static pre-issued `amx` tokens) --------------------
# Lookups (GetCustomerSearch / GetLoanByMobileNumber / GetLoanAgreementNoAsync
# / GetRepaymentForLoanByLoanId) use the apiv2 host + APIV2_AUTH_SMSQUARE.
APIV2_AUTH_SMSQUARE=
# Payment gateway (GetQRCode) uses the "api" host + PG_API_AUTH_SMSQUARE.
PG_API_AUTH_SMSQUARE=
# LCC (Loan Collection) voicecall details (GetLccDetailsByAgreementNo).
LCC_API_AUTH_SMSQUARE=
# Note: saverepayment is NOT called by this portal — see payment_service.py.

# --- Portal behaviour --------------------------------------------------------
SESSION_IDLE_MINUTES=15
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_SECONDS=30
OTP_HOURLY_LIMIT=5
MIN_PART_PAYMENT=100

# Admin key for /dev/lms-probe (leave blank to disable the route). Allowed in
# prod too, but GET-only there.
ADMIN_PROBE_KEY=

# SMS gateway (SmsCountry bulk API). Leave SMSCOUNTRY_USER blank to log the
# OTP to the console instead of sending a real SMS (UAT convenience).
SMSCOUNTRY_URL=https://api.smscountry.com/SMSCwebservice_bulk.aspx
SMSCOUNTRY_USER=
SMSCOUNTRY_PASSWORD=
SMSCOUNTRY_SID=
SMSCOUNTRY_BRAND_NAME=SMSQUARE

# Legal name + address + helpline (same number for calls and WhatsApp) +
# Grievance/FPC footer content
LEGAL_NAME=SMSquare Credit Services Pvt Ltd.
COMPANY_ADDRESS=14th Floor, T 19 Towers, Ranigunj, Secunderabad, Hyderabad. Telangana - 500003
HELPLINE_NUMBER=8333000111
GRIEVANCE_OFFICER=Grievance Officer, SMSquare Credit Services
GRIEVANCE_EMAIL=support@smsquare.info
GRIEVANCE_PHONE=+91-00000-00000
OMBUDSMAN_URL=https://cms.rbi.org.in
